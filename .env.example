# =========================================================
# SolarOS — variables de entorno
# Copia este archivo como .env.local y rellena los valores.
# .env.local NUNCA se commitea (ya está en .gitignore).
# =========================================================

# ---- Clerk (auth + organizations) ----
# Dashboard: https://dashboard.clerk.com → API keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Webhook signing secret: Dashboard → Webhooks → endpoint del proyecto
CLERK_WEBHOOK_SIGNING_SECRET=
# URLs de las páginas de Clerk dentro de la app
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ---- Supabase (Postgres) ----
# Dual-role architecture (see ADR-0004):
#   DATABASE_URL → app_user (no BYPASSRLS) — runtime adapter for Prisma.
#   DIRECT_URL   → postgres (BYPASSRLS)    — migrations + admin scripts.
# Runtime URL (transaction pooler, port 6543). Connects as app_user so
# RLS policies are enforced. The password matches APP_USER_PASSWORD.
DATABASE_URL=postgresql://app_user.<PROJECT_REF>:<APP_USER_PASSWORD>@aws-X-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Migrations URL (session pooler, port 5432). Connects as postgres
# because pgbouncer transaction mode does not support full DDL.
DIRECT_URL=postgresql://postgres.<PROJECT_REF>:<POSTGRES_PASSWORD>@aws-X-eu-central-1.pooler.supabase.com:5432/postgres
# Password for the app_user role. Generated LOCALLY — never via chat
# with an assistant. See ADR-0004 → "Regla de proceso — gestión de la
# password de app_user". Consumed by `pnpm db:bootstrap-app-user` and
# embedded into DATABASE_URL above.
APP_USER_PASSWORD=<generate_locally_see_adr_0004>
# Cliente JS (uso futuro: realtime, RLS desde browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: solo server-side, NUNCA exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=

# ---- Cloudflare R2 (object storage) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ---- Resend (email transaccional) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ---- Sentry (error monitoring) ----
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ---- PostHog (product analytics) ----
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
