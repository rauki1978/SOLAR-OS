{
  "name": "@solaros/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf node_modules .turbo",
    "db:generate": "prisma generate",
    "db:push": "prisma db push --skip-generate",
    "db:migrate": "prisma migrate dev && prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset && prisma generate",
    "db:check": "tsx ./scripts/check-connection.ts",
    "db:bootstrap-app-user": "tsx scripts/bootstrap-app-user.ts",
    "db:verify-app-user": "tsx scripts/verify-app-user.ts",
    "db:forget-migration": "tsx scripts/forget-migration.ts",
    "db:whoami": "tsx scripts/whoami.ts",
    "db:smoke-rls": "tsx scripts/smoke-rls.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@solaros/config": "workspace:*",
    "@types/pg": "^8.11.0",
    "dotenv": "^17.0.0",
    "eslint": "^9.0.0",
    "prisma": "^7.0.0",
    "rimraf": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
